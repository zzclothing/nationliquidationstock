<%- include('../partials/head') %>
<%- include('../partials/header') %>
<%- include('../partials/alerts') %>
<main class="container page-grid">
  <aside class="card filter-card">
    <p class="eyebrow"><%= t('products_search_eyebrow') %></p>
    <h2><%= t('products_refine_title') %></h2>
    <form action="/products" method="get" class="filter-form">
      <input type="text" name="q" placeholder="<%= t('products_keyword_placeholder') %>" value="<%= filters.q %>">
      <select name="category">
        <option value=""><%= t('products_all_categories') %></option>
        <% categories.forEach((category) => { %><option value="<%= category %>" <%= filters.category === category ? 'selected' : '' %>><%= translateCategory(category) %></option><% }) %>
      </select>
      <button class="button" type="submit"><%= t('products_apply_filters') %></button>
    </form>
  </aside>

  <section class="results-panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow"><%= t('products_catalog_eyebrow') %></p>
        <h1><%= t('products_catalog_title') %></h1>
      </div>
      <span><%= products.length %> <%= t('products_loads') %></span>
    </div>

    <div class="product-grid catalog-grid">
      <% products.forEach((product) => { %>
        <article class="product-card card">
          <img src="<%= product.images && product.images.length ? product.images[0] : '/images/products/mixed-gm-1.svg' %>" alt="<%= product.title %>">
          <div class="product-card-body">
            <div class="card-topline"><span><%= translateCategory(product.category) %></span><span><%= translateCondition(product.condition) %></span></div>
            <h3><%= product.title %></h3>
            <p><%= product.description %></p>
            <div class="meta-row"><span><%= product.quantityAvailable %> <%= t('products_available') %></span><span><%= product.reviewCount %> <%= t('products_reviews') %></span></div>
            <div class="card-bottom">
              <strong><%= formatCurrency(product.priceCents) %> / <%= translateUnit(product.unitType) %></strong>
              <a class="button button-small" href="/products/<%= product.slug %>"><%= t('products_view_load') %></a>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
