<%- include('../partials/head') %>
<%- include('../partials/header') %>
<%- include('../partials/alerts') %>
<main class="container auth-shell">
  <form class="card form-grid auth-card" action="/login" method="post">
    <h1><%= t('auth_login_heading') %></h1>
    <% if (typeof errors !== 'undefined') { %><div class="inline-errors"><% errors.forEach((error) => { %><p><%= error %></p><% }) %></div><% } %>
    <input type="email" name="email" placeholder="<%= t('common_work_email') %>" value="<%= (typeof form !== 'undefined' && form && form.email) ? form.email : '' %>" required>
    <input type="password" name="password" placeholder="<%= t('common_password') %>" required>
    <button class="button" type="submit"><%= t('auth_sign_in') %></button>
    <a href="/forgot-password"><%= t('auth_forgot_password') %></a>
    
</main>
<%- include('../partials/footer') %>
